# ============================================================
# 怡安印刷商城 — 开发环境 PHP 8.5 Dockerfile
# 比生产镜像轻量，包含 Xdebug 和 Composer
# ============================================================

FROM php:8.5-fpm-alpine

LABEL maintainer="yian-dev"

# 安装系统依赖
RUN apk add --no-cache \
    git \
    unzip \
    zip \
    curl \
    libpng-dev \
    libjpeg-turbo-dev \
    freetype-dev \
    libzip-dev \
    icu-dev \
    oniguruma-dev \
    libxml2-dev \
    linux-headers \
    $PHPIZE_DEPS

# 安装 PHP 扩展
RUN docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install -j$(nproc) \
        pdo_mysql \
        mysqli \
        gd \
        zip \
        intl \
        bcmath \
        opcache \
        pcntl \
        sockets \
        exif \
        xml \
        mbstring

# 安装 Redis 扩展
RUN pecl install redis \
    && docker-php-ext-enable redis

# 安装 Xdebug（开发环境专用）
RUN pecl install xdebug \
    && docker-php-ext-enable xdebug

# 安装 Swoole（Octane 需要）
RUN pecl install swoole-5.1.5 \
    && docker-php-ext-enable swoole

# 安装 Composer
COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

# 创建日志目录
RUN mkdir -p /var/log/php /var/www/html/storage/logs \
    && chown -R www-data:www-data /var/www/html /var/log/php

WORKDIR /var/www/html

EXPOSE 9000

CMD ["php-fpm"]
